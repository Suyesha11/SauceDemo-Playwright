{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
       // "moduleResolution": "node10",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true,
        "types": [
            "node"
        ],
        //"baseUrl": "."
    },
    "include": [
        "**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "playwright-report",
        "test-results"
    ]
}